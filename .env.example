# ── DB ──────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=easit
DB_PASS=easit1234
DB_NAME=easit

# ── JWT ─────────────────────────────────────────────
JWT_SECRET=여기에_32자_이상_랜덤_문자열_입력

# ── 카카오 ───────────────────────────────────────────
# developers.kakao.com → 내 애플리케이션 → 앱 키
KAKAO_REST_API_KEY=여기에_카카오_REST_API_키
KAKAO_CALLBACK_URL=http://localhost:3000/api/auth/kakao/callback

# ── 네이버 ───────────────────────────────────────────
# developers.naver.com → Application → 네이버 로그인
NAVER_CLIENT_ID=여기에_네이버_클라이언트_ID
NAVER_CLIENT_SECRET=여기에_네이버_클라이언트_시크릿
NAVER_CALLBACK_URL=http://localhost:3000/api/auth/naver/callback

# ── 구글 ─────────────────────────────────────────────
# console.cloud.google.com → API 및 서비스 → 사용자 인증정보
GOOGLE_CLIENT_ID=여기에_구글_클라이언트_ID
GOOGLE_CLIENT_SECRET=여기에_구글_클라이언트_시크릿
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# ── 지하철 API ────────────────────────────────────────
# data.seoul.go.kr → 인증키 발급
SEOUL_API_KEY=여기에_서울_열린데이터_API_키
# tago.go.kr → 회원가입 후 인증키 발급
TAGO_API_KEY=여기에_TAGO_API_키

# ── 프론트엔드 URL ──────────────────────────────────────
FRONTEND_URL=http://localhost:5173
